<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
<LinearLayout
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="80dp"
    tools:context=".MainActivity">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Задание 1"
        android:textSize="20sp"
        android:textStyle="bold"
        android:layout_margin="16dp" />

    <Button
        android:layout_width="175dp"
        android:layout_height="175dp"
        android:text="Узнать фамилию"
        android:id="@+id/button1" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Задание 2"
        android:textSize="20sp"
        android:textStyle="bold"
        android:layout_margin="16dp" />

    <Button
        android:layout_width="175dp"
        android:layout_height="175dp"
        android:text="Привет"
        android:id="@+id/button2" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Задание 3"
        android:textSize="20sp"
        android:textStyle="bold"
        android:layout_margin="16dp" />

    <Button
        android:layout_width="175dp"
        android:layout_height="175dp"
        android:text="Кнопка 1"
        android:id="@+id/button3" />

    <Button
        android:layout_width="175dp"
        android:layout_height="175dp"
        android:text="Кнопка 2"
        android:id="@+id/button4" />

    <Button
        android:layout_width="175dp"
        android:layout_height="175dp"
        android:text="Кнопка 3"
        android:id="@+id/button5" />


    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Задание 4"
        android:textSize="20sp"
        android:textStyle="bold"
        android:layout_margin="16dp" />

    <Button
        android:layout_width="175dp"
        android:layout_height="175dp"
        android:text="Кнопка 4"
        android:id="@+id/button6" />

    <Button
        android:layout_width="175dp"
        android:layout_height="175dp"
        android:text="Кнопка 5"
        android:id="@+id/button7" />

    <Button
        android:layout_width="175dp"
        android:layout_height="175dp"
        android:text="Кнопка 6"
        android:id="@+id/button8" />


    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Задание 5"
        android:textSize="20sp"
        android:textStyle="bold"
        android:layout_margin="16dp" />

    <Button
        android:layout_width="175dp"
        android:layout_height="175dp"
        android:text="Режим А"
        android:id="@+id/button9" />

    <Button
        android:layout_width="175dp"
        android:layout_height="175dp"
        android:text="Режим Б"
        android:id="@+id/button10" />

</LinearLayout>
</ScrollView>